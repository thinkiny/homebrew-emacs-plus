+static void
+nsxwidget_apply_view_clear_background (NSView *view)
+{
+  if (view == nil)
+    return;
+
+  SEL set_opaque = NSSelectorFromString (@"setOpaque:");
+  SEL set_background_color = NSSelectorFromString (@"setBackgroundColor:");
+
+  if ([view respondsToSelector:set_opaque])
+    ((void (*)(id, SEL, BOOL)) objc_msgSend) (view, set_opaque, NO);
+
+  if ([view respondsToSelector:set_background_color])
+    ((void (*)(id, SEL, id)) objc_msgSend) (view, set_background_color,
+                                            [NSColor clearColor]);
+
+  [view setWantsLayer:YES];
+  if ([view layer] != nil)
+    {
+      [[view layer] setOpaque:NO];
+      [[view layer] setBackgroundColor:[[NSColor clearColor] CGColor]];
+    }
+}
+
+static void
+nsxwidget_apply_webview_transparency (WKWebView *webview)
+{
+  if (webview == nil)
+    return;
+
+  SEL set_draws_background = NSSelectorFromString (@"setDrawsBackground:");
+  SEL set_draws_background_priv = NSSelectorFromString (@"_setDrawsBackground:");
+  SEL set_under_page_background_color =
+    NSSelectorFromString (@"setUnderPageBackgroundColor:");
+  SEL scroll_view_sel = NSSelectorFromString (@"scrollView");
+  NSScrollView *scroll_view = nil;
+
+  nsxwidget_apply_view_clear_background ((NSView *) webview);
+
+  if ([webview respondsToSelector:set_draws_background])
+    ((void (*)(id, SEL, BOOL)) objc_msgSend) (webview, set_draws_background,
+                                              NO);
+  if ([webview respondsToSelector:set_draws_background_priv])
+    ((void (*)(id, SEL, BOOL)) objc_msgSend) (webview,
+                                              set_draws_background_priv,
+                                              NO);
+  if ([webview respondsToSelector:set_under_page_background_color])
+    ((void (*)(id, SEL, id)) objc_msgSend) (webview,
+                                            set_under_page_background_color,
+                                            [NSColor clearColor]);
+
+  @try
+    {
+      [webview setValue:@NO forKey:@"drawsBackground"];
+      [webview setValue:[NSColor clearColor] forKey:@"underPageBackgroundColor"];
+    }
+  @catch (NSException *ignored)
+    {
+    }
+
+  if ([webview respondsToSelector:scroll_view_sel])
+    scroll_view = ((id (*)(id, SEL)) objc_msgSend) (webview, scroll_view_sel);
+
+  nsxwidget_apply_view_clear_background ((NSView *) scroll_view);
+  nsxwidget_apply_view_clear_background ([scroll_view contentView]);
+  nsxwidget_apply_view_clear_background ([[scroll_view contentView] documentView]);
+}
+
+static void
+nsxwidget_refresh_transparency_for_view (struct xwidget_view *xv)
+{
+  if (xv == NULL || EQ (xv->model, Qnil))
+    return;
+
+  struct xwidget *xw = XXWIDGET (xv->model);
+  if (xw == NULL || xw->xwWidget == nil)
+    return;
+
+  nsxwidget_apply_webview_transparency ((WKWebView *) xw->xwWidget);
+
+  xv->xvWindow.needsDisplay = YES;
+  xw->xwWindow.needsDisplay = YES;
+  ((NSView *) xw->xwWidget).needsDisplay = YES;
+
+  nsxwidget_invalidate_host_for_view (xv);
+}
+
+static void
+nsxwidget_invalidate_host_for_view (struct xwidget_view *xv)
+{
+  if (xv->emacswindow)
+    {
+      NSWindow *window = [xv->emacswindow window];
+      NSView *content = window ? [window contentView] : nil;
+      [xv->emacswindow setNeedsDisplay:YES];
+      [xv->emacswindow setNeedsDisplayInRect:[xv->xvWindow frame]];
+      if (window)
+        [window setViewsNeedDisplay:YES];
+      if (content)
+        {
+          [content setNeedsDisplay:YES];
+          [content setNeedsDisplayInRect:[xv->xvWindow frame]];
+        }
+    }
 }
