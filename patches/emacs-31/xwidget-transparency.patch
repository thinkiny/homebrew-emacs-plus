+void
+ns_clear_xwidget_underlay (struct xwidget_view *xv,
+                           int x, int y, int width, int height,
+                           const char *reason,
+                           bool wake_app_loop)
+{
+  (void) reason;
+
+  if (xv == NULL || EQ (xv->w, Qnil) || !WINDOWP (xv->w))
+    return;
+
+  if (width <= 0 || height <= 0)
+    return;
+
+  struct window *w = XWINDOW (xv->w);
+  struct frame *f = w ? WINDOW_XFRAME (w) : NULL;
+  NSView *view = nil;
+  NSRect rect = NSMakeRect (x, y, width, height);
+  struct face *face = NULL;
+
+  if (f == NULL || !FRAME_LIVE_P (f))
+    return;
+
+  view = FRAME_NS_VIEW (f);
+  face = FRAME_DEFAULT_FACE (f);
+  if (view == nil || face == NULL)
+    return;
+
+  rect = NSIntersectionRect (rect, [view frame]);
+  if (NSIsEmptyRect (rect))
+    return;
+
+  ns_focus (f, &rect, 1);
+  [[[NSColor colorWithUnsignedLong:NS_FACE_BACKGROUND (face)]
+    colorWithAlphaComponent:f->alpha_background] set];
+  /* Replace stale backing pixels rather than blending over them.  */
+  NSRectFillUsingOperation (rect, NSCompositingOperationCopy);
+  ns_unfocus (f);
+
+  [view setNeedsDisplayInRect:rect];
+  if ([view window])
+    [[view window] setViewsNeedDisplay:YES];
+  if (wake_app_loop)
+    ns_send_appdefined (-1);
+}
