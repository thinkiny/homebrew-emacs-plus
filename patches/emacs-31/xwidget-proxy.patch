+
+static void
+nsxwidget_apply_proxy_to_configuration (WKWebViewConfiguration *configuration)
+{
+  if (configuration == nil)
+    return;
+
+  WKWebsiteDataStore *data_store = configuration.websiteDataStore;
+  Lisp_Object proxy_sym =
+    Fintern (build_string ("xwidget-webkit-proxy"), Qnil);
+  Lisp_Object proxy_value = Fsymbol_value (proxy_sym);
+  nw_endpoint_t endpoint = NULL;
+  nw_proxy_config_t proxy_config = NULL;
+  NSURLComponents *components = nil;
+  NSString *scheme = nil;
+  NSString *host = nil;
+  NSString *port = nil;
+  NSString *username = nil;
+  NSString *password = nil;
+
+  if (NILP (proxy_value) || !STRINGP (proxy_value))
+    {
+      data_store.proxyConfigurations = nil;
+      return;
+    }
+
+  components =
+    [NSURLComponents
+      componentsWithString:[NSString stringWithLispString:proxy_value]];
+  scheme = [components.scheme lowercaseString];
+  host = components.host;
+  port = components.port
+    ? [components.port stringValue]
+    : ([scheme isEqualToString:@"http"] ? @"80"
+       : [scheme isEqualToString:@"https"] ? @"443"
+       : [scheme isEqualToString:@"socks5"] ? @"1080"
+       : nil);
+  username = components.user;
+  password = components.password;
+
+  if (scheme == nil || host == nil || [host length] == 0
+      || port == nil || [port length] == 0)
+    {
+      data_store.proxyConfigurations = nil;
+      return;
+    }
+
+  endpoint = nw_endpoint_create_host ([host UTF8String], [port UTF8String]);
+  if (endpoint == NULL)
+    {
+      data_store.proxyConfigurations = nil;
+      return;
+    }
+
+  if ([scheme isEqualToString:@"socks5"])
+    proxy_config = nw_proxy_config_create_socksv5 (endpoint);
+  else if ([scheme isEqualToString:@"http"])
+    proxy_config = nw_proxy_config_create_http_connect (endpoint, NULL);
+  else if ([scheme isEqualToString:@"https"])
+    {
+      nw_protocol_options_t tls_options = nw_tls_create_options ();
+      proxy_config = nw_proxy_config_create_http_connect (endpoint, tls_options);
+      if (tls_options)
+        nw_release (tls_options);
+    }
+
+  if (proxy_config == NULL)
+    {
+      nw_release (endpoint);
+      data_store.proxyConfigurations = nil;
+      return;
+    }
+
+  if (username != nil && [username length] > 0)
+    nw_proxy_config_set_username_and_password (
+      proxy_config, [username UTF8String],
+      (password != nil && [password length] > 0)
+      ? [password UTF8String] : NULL);
+
+  data_store.proxyConfigurations = [NSArray arrayWithObject:proxy_config];
+  nw_release (proxy_config);
+  nw_release (endpoint);
+}
